{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "electron/compiled",
    "rootDir": "electron/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["electron/src/main.ts", "electron/src/preload.ts", "electron/src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "electron/src/renderer"]
}
