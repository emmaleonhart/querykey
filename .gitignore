# Personal chat-log corpus — context for the QueryKey pivot.
# These exports (Discord DMs, Claude/Grok/ChatGPT conversations, voice
# transcripts, etc.) contain private/personal information about real people
# and must NEVER be committed. They are a corpus to read selectively, not a
# spec. Only this directory's README is tracked.
/chat/*
!/chat/README.md
# chat/public/ holds non-personal, committable chats (vision/strategy
# discussions with no private info). Everything directly under chat/
# stays ignored; chat/public/ is tracked.
!/chat/public/

# Scheduler runtime (durable cron lock/state) — never commit.
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Rust server build output + runtime Loca databases.
/server/target/
**/*.sdb/
*.sdb
