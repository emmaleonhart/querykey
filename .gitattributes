# Normalize text files to LF on commit and in the working tree, so
# editing on Windows (where core.autocrlf=true is common) doesn't
# rewrite every line in a diff. Without this, a one-line tweak to a
# .rs/.toml/.md file looks like a full rewrite — see commit history
# around 2026-05-15 for the incident this prevents.

* text=auto eol=lf

# Source: always LF.
*.rs       text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.go       text eol=lf
*.dart     text eol=lf
*.py       text eol=lf
*.sh       text eol=lf

# Windows scripts: keep CRLF.
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Binary — never normalize.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.sdb      binary
*.wav      binary
*.mp3      binary
*.mp4      binary
